# ─── Яндекс.Wordstat ──────────────────────────────────────────────────────────
YANDEX_LOGIN=your_login@yandex.ru
YANDEX_PASSWORD=your_password

# ─── Регион ───────────────────────────────────────────────────────────────────
# 213 = Москва | 2 = Санкт-Петербург | 225 = Россия | 54 = Екатеринбург
REGION_ID=213

# ─── Serpstat (опционально) ───────────────────────────────────────────────────
SERPSTAT_API_KEY=

# ─── Настройки парсинга ───────────────────────────────────────────────────────
WORDSTAT_PAGES=3        # страниц Wordstat на один запрос (≈50 ключей/стр)
SERP_TOP_N=10           # конкурентов из ТОП
CLUSTERS_N=15           # кол-во LSI-кластеров
HEADLESS=true           # true = браузер без GUI

# ─── Пути ─────────────────────────────────────────────────────────────────────
OUTPUT_DIR=output
